  },
  "scripts": {
    "critical-css": "sass src/stylesheets/critical.scss | yarn run postcss --use autoprefixer --use cssnano -o build/critical.css --no-map",
    "apply-critical-css": "sed -e 's/<\\/head>/\\\nHERE\\\n/' build/index.html | awk '!/HERE/ { print } /HERE/ { print \"<style type=\\\"text/css\\\">\"; while ((getline a < \"build/critical.css\") > 0) print a; print \"</style></head>\" }' > build/critical.html",
    "build:css": "echo '>>> Building CSS'; yarn critical-css && yarn apply-critical-css",
    "build:svgs": "echo '>>> Building Icons...'; npx @svgr/cli -d src/images/ --ignore-existing src/images/",
    "analyze": "yarn build:production && source-map-explorer build/static/js/main.*",
    "start-server:live": "cross-env NODE_ENV=development npx nodemon server/index.js",
    "start-server": "cross-env NODE_ENV=development node server/index.js",
    "start-server:debug": "cross-env NODE_ENV=development ndb server/index.js",
    "start-server:production": "cross-env NODE_ENV=production node server/index.js",
    "start": "npm-run-all -p  start-js start-server",
    "start:live": "npm-run-all -p start-js start-server:live",
    "build": "sh -ac '. ./.env; yarn build:svgs && yarn build:scripts && yarn build:css'",
    "build:local": "cross-env REACT_APP_ENV=production sh -ac '. ./.env; yarn build:svgs && yarn build:scripts && yarn build:css'",
    "build:staging": "REACT_APP_ENV=staging yarn build",
    "build:production": "REACT_APP_ENV=production yarn build",
    "build:suitcase": "REACT_APP_ENV=suitcase yarn build",
    "test": "react-scripts test --verbose --watchAll",
    "test:coverage": "react-scripts test --verbose --watchAll --coverage",
    "lint": "yarn run eslint src",
    "lint:fix": "yarn run lint --fix",
    "prepare": "husky install",
    "start-js": "vite",
    "build:scripts": "vite build",
    "preview": "vite preview"
  },
